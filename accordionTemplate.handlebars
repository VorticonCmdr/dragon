{{#each hits}}
<div class="accordion-item">
  <h2 class="accordion-header" id="heading{{@index}}">
    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{@index}}">
      {{this.keyword}}
    </button>
  </h2>
  <div id="collapse{{@index}}" class="accordion-collapse collapse" data-bs-parent="#accordionRelated">
    <div class="accordion-body">
      <h5 class="card-title"><a href="{{{this.url}}}" target="_blank">{{this.og_title}}</a></h5>
      <small class="card-subtitle mb-2 text-muted">{{this.og_description}}</small>
    </div>
  </div>
</div>
{{/each}}
