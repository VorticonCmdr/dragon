{
  "permissions": ["storage", "unlimitedStorage", "webRequest", "alarms", "notifications", "declarativeNetRequest", "declarativeNetRequestWithHostAccess"],
  "options_page": "options.html",
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/dragon16.png",
    "32": "icons/dragon32.png",
    "64": "icons/dragon64.png",
    "128": "icons/dragon128.png"
  },
  "action": {
    "default_title": "blue dragon"
  },
  "description": "an experimental crawler in Google Chrome",
  "manifest_version": 3,
  "name": "blue dragon",
  "homepage_url": "https://valentin.app/blue-dragon.html",
  "version": "0.0.0.5"
}
